{% extends 'base.html.twig' %}

{% block title %}Dashboard Admin{% endblock %}

{% block body %}
    <h1 class="bold text-3xl text-white text-center bg-gray-800 mb-6 py-4">Dashboard Administrateur</h1>

    <div class="max-w-6xl mx-auto px-4">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
            <div class="bg-white rounded-lg shadow-md p-6">
                <h2 class="text-xl font-bold text-gray-700 mb-2">Soirées</h2>
                <p class="text-4xl font-bold text-blue-600">{{ soirees|length }}</p>
                <a href="{{ path('app_admin_soiree_index') }}" class="inline-block mt-4 text-blue-500 hover:text-blue-700">Gérer les soirées →</a>
            </div>

            <div class="bg-white rounded-lg shadow-md p-6">
                <h2 class="text-xl font-bold text-gray-700 mb-2">Matériels</h2>
                <p class="text-4xl font-bold text-green-600">{{ materiels|length }}</p>
                <a href="{{ path('app_admin_materiel_index') }}" class="inline-block mt-4 text-green-500 hover:text-green-700">Gérer les matériels →</a>
            </div>

            <div class="bg-white rounded-lg shadow-md p-6">
                <h2 class="text-xl font-bold text-gray-700 mb-2">Thèmes</h2>
                <p class="text-4xl font-bold text-purple-600">{{ themes|length }}</p>
                <a href="{{ path('app_admin_theme_index') }}" class="inline-block mt-4 text-purple-500 hover:text-purple-700">Gérer les thèmes →</a>
            </div>

            <div class="bg-white rounded-lg shadow-md p-6">
                <h2 class="text-xl font-bold text-gray-700 mb-2">Artistes</h2>
                <p class="text-4xl font-bold text-orange-600">{{ artistes|length }}</p>
                <a href="{{ path('app_admin_artiste_index') }}" class="inline-block mt-4 text-orange-500 hover:text-orange-700">Gérer les artistes →</a>
            </div>

            <div class="bg-white rounded-lg shadow-md p-6">
                <h2 class="text-xl font-bold text-gray-700 mb-2">Réservations</h2>
                <p class="text-4xl font-bold text-red-600">{{ materielSoirees|length }}</p>
                <a href="{{ path('app_admin_materiel_soiree_index') }}" class="inline-block mt-4 text-red-500 hover:text-red-700">Gérer les résas →</a>
            </div>
        </div>
    </div>
{% endblock %}
